@page "/login"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject AldocWeb.Services.AppSession Session

<PageTitle>Iniciar sesión — Aldoc</PageTitle>

<div style="min-height:100vh;display:flex;align-items:flex-start;justify-content:center;background:#fff;overflow-y:auto;padding:60px 36px 80px;">
    <div style="width:100%;max-width:320px;display:flex;flex-direction:column;align-items:center;gap:40px;">

        <!-- Logo -->
        <img src="/images/logo.svg" alt="aldoc" style="width:144px;height:40px;" />

        <!-- Title -->
        <p style="font-size:20px;font-weight:700;line-height:1.5;color:#3B6FB8;text-align:center;">
            Bienvenido/a
        </p>

        <!-- Form -->
        <div style="display:flex;flex-direction:column;gap:20px;width:100%;">

            <div class="field">
                <label>Correo</label>
                <input type="email" placeholder="Ingrese su correo" @bind="_email" @bind:event="oninput" />
            </div>

            <div class="field">
                <label>Contraseña</label>
                <div style="position:relative;">
                    <input type="@(_showPwd ? "text" : "password")"
                           placeholder="Ingrese su contraseña"
                           @bind="_password" @bind:event="oninput"
                           style="padding-right:44px;width:100%;height:44px;padding-left:14px;font-family:var(--font);font-size:16px;color:var(--color-text);background:#fff;border:1px solid var(--color-border);border-radius:var(--radius-input);outline:none;" />
                    <button type="button"
                            @onclick="() => _showPwd = !_showPwd"
                            style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;padding:0;color:#94A3B8;display:flex;align-items:center;">
                        @if (_showPwd)
                        {
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                        }
                        else
                        {
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        }
                    </button>
                </div>
            </div>

            <button class="btn-primary" disabled="@(!CanLogin)" @onclick="HandleLogin">
                Iniciar sesión
            </button>

            <p style="font-size:14px;text-align:center;color:#3B6FB8;">
                ¿No tienes cuenta?
                <a href="/crear-cuenta" style="color:#3B6FB8;font-weight:600;">Regístrate acá</a>
            </p>
        </div>
    </div>
</div>

@code {
    private string _email = "";
    private string _password = "";
    private bool _showPwd = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !Session.SplashShown)
            Nav.NavigateTo("/", replace: true);
    }

    private bool CanLogin => !string.IsNullOrWhiteSpace(_email) && !string.IsNullOrWhiteSpace(_password);

    private void HandleLogin()
    {
        if (CanLogin) Nav.NavigateTo("/dashboard");
    }
}
