@page "/"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject AldocWeb.Services.AppSession Session
@implements IDisposable

<PageTitle>Aldoc</PageTitle>

<div style="position:fixed;inset:0;overflow:hidden;background:linear-gradient(180deg,#79C3FF 0.96%,#163F79 100%);">

    <!-- Foto de fondo al 20% -->
    <div style="position:absolute;inset:0;background-image:url('/images/splash-bg.jpg');background-size:cover;background-position:center;opacity:0.20;"></div>

    <!-- Contenido centrado -->
    <div style="position:relative;z-index:1;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:24px;">

        <!-- Logo blanco -->
        <img src="/images/logo-white.svg" alt="aldoc" style="width:136px;height:39px;" />

        <!-- Tagline -->
        <p style="font-family:'Open Sans',sans-serif;font-size:20px;line-height:1.5;letter-spacing:-0.6px;color:#fff;text-align:center;width:280px;margin:0;">
            <span style="font-weight:700;">Cuidar </span><span style="font-weight:300;">de tu </span><span style="font-weight:700;">salud </span><span style="font-weight:300;">es nuestro </span><span style="font-weight:700;">propósito</span>
        </p>
    </div>
</div>

@code {
    private CancellationTokenSource _cts = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await Task.Delay(3000, _cts.Token);
                Session.SplashShown = true;
                Nav.NavigateTo("/login");
            }
            catch (TaskCanceledException) { }
        }
    }

    public void Dispose() => _cts.Cancel();
}
