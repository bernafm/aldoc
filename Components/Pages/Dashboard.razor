@code {
    private int _estado = 2; // 0=nuevo, 1=incompleto, 2=parcial, 3=completo

    // Datos por estado
    private int HeroNum => _estado switch { 0 => 0, 1 => 0, 2 => 1, _ => 4 };
    private string HeroSaludo => _estado switch { 0 or 1 => "¡Buenos días Berni!", _ => "¡Buenas noches Berni!" };
    private string HeroSubtitulo => _estado switch {
        0 or 1 => "Tu registro de salud empieza aquí",
        2 => "Vas muy bien! Mantén tu ritmo",
        _ => "Completaste todos tus hábitos hoy. Bien hecho."
    };
    private bool _calOk  => _estado == 2 || _estado == 3;
    private bool _aguaOk => _estado == 3;
    private bool _movOk  => _estado == 3;
    private bool _pasosOk => _estado == 3;

    // SVG gauge
    private const double R = 38, Circ = 2 * Math.PI * R, Arc = Circ * 0.75;
    private string TrackDash => $"{Arc:F1} {Circ:F1}";
    private string ProgressDash => $"{Arc * HeroNum / 4.0:F1} {Circ:F1}";

    // Mediciones como RenderFragment
    private RenderFragment MedicionesRow =>
    @<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;">
