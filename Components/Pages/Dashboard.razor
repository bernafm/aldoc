@page "/dashboard"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject AldocWeb.Services.AppSession Session

<PageTitle>Inicio — Aldoc</PageTitle>

<div class="dash-root">

    <!-- Top bar -->
    <div class="dash-topbar">
        <img src="/images/logo.svg" alt="aldoc" class="dash-topbar-logo" />
        <div class="dash-topbar-icons">
            <button class="dash-icon-btn">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#64748B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                </svg>
            </button>
            <button class="dash-icon-btn">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#64748B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- Dev: selector de estado -->
    <div style="display:flex;gap:6px;padding:8px 16px;background:#F1F5F9;border-bottom:1px solid #E2E8F0;overflow-x:auto;">
        @foreach (var (label, idx) in new[]{("Nuevo",0),("Incompleto",1),("Parcial",2),("Completo",3)})
        {
            <button @onclick="() => _estado = idx"
                    style="padding:4px 12px;border-radius:100px;border:none;font-family:'Open Sans',sans-serif;font-size:11px;font-weight:600;cursor:pointer;white-space:nowrap;background:@(_estado==idx?"#3B6FB8":"#fff");color:@(_estado==idx?"#fff":"#64748B");">
                @label
            </button>
        }
    </div>

    <!-- Scrollable content -->
    <div class="dash-scroll">

        <!-- ═══ ESTADO 0: Usuario nuevo ═══ -->
        @if (_estado == 0)
        {
            <div class="dash-welcome">
                <div class="dash-welcome-header">
                    <div class="dash-welcome-avatar">
                        <img src="/images/doctor.svg" alt="" />
                    </div>
                    <div>
                        <p class="dash-welcome-title">¡Bienvenido a Aldoc!</p>
                        <p class="dash-welcome-sub">Configura tu perfil para que podamos acompañarte mejor en tu salud.</p>
                    </div>
                </div>
                <div class="dash-welcome-list">
                    <div class="dash-welcome-item"><span>❤️</span><span>Completa tu ficha de salud</span></div>
                    <div class="dash-welcome-item"><span>🔥</span><span>Registra lo que comes hoy</span></div>
                    <div class="dash-welcome-item"><span>🥛</span><span>Lleva tu hidratación</span></div>
                    <div class="dash-welcome-item"><span>⏱️</span><span>Anota tu movimiento diario</span></div>
                </div>
                <button class="dash-welcome-cta">
                    Comenzar configuración
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </button>
            </div>

            <p class="dash-section-title">Hábitos</p>
            <div class="dash-habits-grid">
                @HabitoVacio("Calorías", "cal", "0", "Kcal", "de 2000 kcal", camara: true)
                @HabitoVacio("Movimiento", "mov", "0", "min/sem", "de 300 min/sem")
                @HabitoVacio("Agua", "agua", "0", "vasos", "de 8", plusMinus: true)
                @HabitoVacio("Pasos", "pasos", "0", "pasos", "de 8.000 pasos")
            </div>

            <p class="dash-section-title">Próximas citas</p>
            <div class="dash-cita-empty">
                <span class="dash-cita-empty-text">No tienes consultas</span>
                <button class="dash-cita-empty-btn">Agendar</button>
            </div>

            <p class="dash-section-title">Mis mediciones</p>
            @MedicionesRow
        }

        <!-- ═══ ESTADOS 1, 2, 3: con hero card ═══ -->
        @if (_estado >= 1)
        {
            <!-- Hero card -->
            <div class="dash-hero @(_estado == 3 ? "dash-hero--done" : "")">
                <div class="dash-hero-body">
                    <!-- Gauge: arco 270° (herradura, gap abajo) -->
                    <svg width="90" height="90" viewBox="0 0 100 100" style="flex-shrink:0;overflow:visible;">
                        <!-- Track gris claro (fondo del arco) -->
                        <path d="@GaugePath" fill="none"
                              stroke="#D8E8F8" stroke-width="11" stroke-linecap="round"/>
                        <!-- Progreso verde (solo si hay avance) -->
                        @if (HeroNum > 0)
                        {
                            <path d="@GaugePath" fill="none"
                                  stroke="#2BC06E" stroke-width="11" stroke-linecap="round"
                                  stroke-dasharray="@GaugeProgressDash"/>
                        }
                        <!-- Número: azul si incompleto, verde si 4/4 -->
                        <text x="50" y="47" text-anchor="middle"
                              font-family="'Open Sans',sans-serif" font-size="22" font-weight="700"
                              fill="@(_estado == 3 ? "#2BC06E" : "#3B6FB8")">@HeroNum</text>
                        <text x="50" y="62" text-anchor="middle"
                              font-family="'Open Sans',sans-serif" font-size="10" font-weight="400"
                              fill="#64748B">de 4</text>
                    </svg>
                    <!-- Texto + checkboxes -->
                    <div class="dash-hero-text">
                        <p class="dash-hero-title">@HeroSaludo</p>
                        <p class="dash-hero-subtitle">@HeroSubtitulo</p>
                        <div class="dash-checks">
                            @CheckItem("Calorías",  _calOk)
                            @CheckItem("Agua",      _aguaOk)
                            @CheckItem("Movimiento",_movOk)
                            @CheckItem("Pasos",     _pasosOk)
                        </div>
                    </div>
                </div>
                <!-- Footer -->
                <div class="dash-hero-footer @(_estado == 3 ? "dash-hero-footer--center" : "")">
                    <span class="dash-hero-stat">
                        <span class="dash-stat-pill">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#F97315" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
                        </span>
                        <strong>7 días</strong> de racha activa!
                    </span>
                    @if (_estado != 3)
                    {
                        <span class="dash-hero-stat">
                            <span class="dash-stat-pill">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="#F97315" stroke="none"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
                            </span>
                            @(4 - HeroNum) hábitos pendientes
                        </span>
                    }
                </div>
            </div>

            <!-- CTA banner (solo estado 1) -->
            @if (_estado == 1)
            {
                <div class="dash-cta-banner">
                    <div class="dash-cta-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B6FB8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                    </div>
                    <div style="flex:1;">
                        <p class="dash-cta-title">Terminar de configurar tu salud</p>
                        <p class="dash-cta-sub">Revisa y completa tu información médica</p>
                    </div>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </div>
            }

            <!-- Mis mediciones (primero en estado 3) -->
            @if (_estado == 3)
            {
                <p class="dash-section-title">Mis mediciones</p>
                @MedicionesRow
            }

            <!-- Próximas citas -->
            <p class="dash-section-title">Próximas citas</p>
            <div class="dash-cita">
                <div class="dash-cita-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3B6FB8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
                </div>
                <div style="flex:1;">
                    <p class="dash-cita-title">Consulta nutricional</p>
                    <p class="dash-cita-sub">7 abr 2026 · 10:30</p>
                </div>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#64748B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>

            <!-- Hábitos (estados 1 y 2) -->
            @if (_estado == 1 || _estado == 2)
            {
                <p class="dash-section-title">Hábitos</p>
                <div class="dash-habits-grid">
                    @HabitoConDatos("Calorías", "cal", "1400", "Kcal", "de 2000 kcal", 70, camara: true)
                    @HabitoConDatos("Movimiento", "mov", "120", "min/sem", "de 300 min/sem", 50)
                    @HabitoConDatos("Agua", "agua", "4", "vasos", "de 8", 40, plusMinus: true)
                    @HabitoConDatos("Pasos", "pasos", "8.200", "pasos", "de 8.000 pasos", 100, done: true, statusText: "¡Objetivo alcanzado!")
                </div>

                <p class="dash-section-title">Mis mediciones</p>
                @MedicionesRow
            }

            <!-- Hábitos completos (estado 3) -->
            @if (_estado == 3)
            {
                <p class="dash-section-title">Hábitos</p>
                <div class="dash-habits-grid">
                    @HabitoConDatos("Calorías", "cal", "2000", "Kcal", "de 2000 kcal", 100, camara: true, done: true, statusText: "¡Cumpliste tu meta!")
                    @HabitoConDatos("Movimiento", "mov", "300", "min/sem", "de 300 min/sem", 100, done: true, statusText: "¡Muy bien!")
                    @HabitoConDatos("Agua", "agua", "8", "vasos", "de 8", 100, plusMinus: true, done: true, statusText: "¡Te mantuviste hidratado hoy!")
                    @HabitoConDatos("Pasos", "pasos", "8.200", "pasos", "de 8.000 pasos", 100, done: true, statusText: "¡Superaste un 10% tu objetivo!")
                </div>
            }
        }

    </div>

    <!-- Bottom nav -->
    <nav class="dash-nav">
        <button class="dash-nav-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
            <span class="dash-nav-label">Nutrición</span>
        </button>
        <button class="dash-nav-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            <span class="dash-nav-label">Mi Salud</span>
        </button>
        <button class="dash-nav-item dash-nav-item--active">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B6FB8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span class="dash-nav-label">Home</span>
        </button>
        <button class="dash-nav-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span class="dash-nav-label">Agenda</span>
        </button>
        <button class="dash-nav-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-4"/><circle cx="20" cy="10" r="2"/></svg>
            <span class="dash-nav-label">ChatDoc</span>
        </button>
    </nav>
</div>

@code {
    private int _estado = 2; // 0=nuevo, 1=incompleto, 2=parcial, 3=completo

    private int    HeroNum      => _estado switch { 2 => 1, 3 => 4, _ => 0 };
    private string HeroSaludo   => _estado <= 1 ? "¡Buenos días Berni!" : "¡Buenas noches Berni!";
    private string HeroSubtitulo => _estado switch {
        1 => "Tu registro de salud empieza aquí",
        2 => "Vas muy bien! Mantén tu ritmo",
        3 => "Completaste todos tus hábitos hoy. Bien hecho.",
        _ => ""
    };
    private bool _calOk   => _estado == 2 || _estado == 3;
    private bool _aguaOk  => _estado == 3;
    private bool _movOk   => _estado == 3;
    private bool _pasosOk => _estado == 3;

    // Gauge: arco de 270° (herradura), no círculo completo
    // r=38, viewBox 0 0 100 100
    // Inicio: 135° SVG → (23.13, 76.87) visual 7-8 en punto
    // Fin:     45° SVG → (76.87, 76.87) visual 4-5 en punto
    // Sentido: clockwise (sweep-flag=1), large-arc-flag=1 porque 270°>180°
    private const string GaugePath =
        "M 23.13 76.87 A 38 38 0 1 1 76.87 76.87";

    // Longitud del arco de 270° = 0.75 * 2π * 38 = 179.07
    private const double GaugeArcLen = 179.07;

    private string GaugeProgressDash =>
        $"{GaugeArcLen * HeroNum / 4.0:F2} {GaugeArcLen:F2}";

    // ── Checkbox item ──
    private RenderFragment CheckItem(string label, bool done) =>
    @<div class="dash-check-item">
        <div class="dash-check-circle @(done ? "dash-check-circle--done" : "")">
            @if (done)
            {
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#2BC06E" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            }
        </div>
        <span class="dash-check-label @(done ? "dash-check-label--done" : "")">@label</span>
    </div>;

    // ── Mediciones ──
    private RenderFragment MedicionesRow =>
    @<div class="dash-mediciones-grid">
        <div class="dash-med-card">
            <div class="dash-med-label-row">
                <div class="dash-med-icon">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#3B6FB8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </div>
                <span class="dash-med-label">Frecuencia cardíaca</span>
            </div>
            <div class="dash-med-value-row">
                <span class="dash-med-value">72</span>
                <span class="dash-med-unit">bpm</span>
            </div>
            <span class="dash-med-time">Hace 2h</span>
        </div>
        <div class="dash-med-card">
            <div class="dash-med-label-row">
                <div class="dash-med-icon">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#3B6FB8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </div>
                <span class="dash-med-label">Peso</span>
            </div>
            <div class="dash-med-value-row">
                <span class="dash-med-value">70</span>
                <span class="dash-med-unit">kg</span>
            </div>
        </div>
    </div>;

    // ── Hábito vacío (estado 0) ──
    private RenderFragment HabitoVacio(string nombre, string tipo, string valor, string unidad, string meta,
        bool camara = false, bool plusMinus = false) =>
    @<div class="dash-habit-card">
        <div class="dash-habit-header">
            <div class="dash-habit-name-row">
                @HabitoIcono(tipo)
                <span class="dash-habit-name">@nombre</span>
            </div>
            <span class="dash-habit-dots">···</span>
        </div>
        <div class="dash-habit-value-row">
            <div>
                <span class="dash-habit-value">@valor</span>
                <span class="dash-habit-unit">@unidad</span>
                <div class="dash-habit-meta">@meta</div>
            </div>
            @if (camara)
            {
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            }
            @if (plusMinus)
            {
                <div class="dash-plus-minus">
                    <button class="dash-pm-btn">−</button>
                    <button class="dash-pm-btn">+</button>
                </div>
            }
        </div>
        <div class="dash-bar-track"><div class="dash-bar-fill dash-bar-fill--@tipo" style="width:0%"></div></div>
        <div class="dash-habit-status">0% completado</div>
    </div>;

    // ── Hábito con datos ──
    private RenderFragment HabitoConDatos(string nombre, string tipo, string valor, string unidad, string meta,
        int pct, bool camara = false, bool plusMinus = false, bool done = false, string statusText = "") =>
    @<div class="dash-habit-card @(done ? $"dash-habit-card--{tipo}-done" : (tipo == "pasos" && pct == 100 ? "dash-habit-card--pasos-active" : ""))">
        <div class="dash-habit-header">
            <div class="dash-habit-name-row">
                @HabitoIcono(tipo)
                <span class="dash-habit-name">@nombre</span>
            </div>
            <span class="dash-habit-dots">···</span>
        </div>
        <div class="dash-habit-value-row">
            <div>
                <span class="dash-habit-value">@valor</span>
                <span class="dash-habit-unit">@unidad</span>
                <div class="dash-habit-meta">@meta</div>
            </div>
            @if (camara)
            {
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            }
            @if (plusMinus)
            {
                <div class="dash-plus-minus">
                    <button class="dash-pm-btn">−</button>
                    <button class="dash-pm-btn">+</button>
                </div>
            }
        </div>
        <div class="dash-bar-track"><div class="dash-bar-fill dash-bar-fill--@tipo" style="width:@(pct)%"></div></div>
        <div class="dash-habit-status @(done || pct == 100 ? $"dash-habit-status--{tipo}" : "")">
            @(string.IsNullOrEmpty(statusText) ? $"{pct}% completado" : statusText)
        </div>
    </div>;

    // ── Iconos por hábito ──
    private RenderFragment HabitoIcono(string tipo) => tipo switch {
        "cal"   => @<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F97315" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>,
        "mov"   => @<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6A8BEF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>,
        "agua"  => @<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#79C3FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>,
        _       => @<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#009C8B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="1"/><path d="M6 9l3 1 1 6 2-4 2 4 1-6 3-1"/><circle cx="7" cy="20" r="1"/><circle cx="17" cy="20" r="1"/></svg>
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !Session.SplashShown)
            Nav.NavigateTo("/", replace: true);
    }
}
