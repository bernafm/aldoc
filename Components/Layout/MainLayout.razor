@inherits LayoutComponentBase

<MudThemeProvider Theme="_aldocTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="aldoc-app-shell">
    @Body
</div>

@code {
    private MudTheme _aldocTheme = new MudTheme
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#3b6fb8",
            PrimaryContrastText = "#ffffff",
            Background = "#ffffff",
            Surface = "#f8fafc",
            TextPrimary = "#334155",
            TextSecondary = "#64748b",
            ActionDefault = "#94a3b8",
            LinesDefault = "#e2e8f0",
            TableLines = "#e2e8f0",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["Open Sans", "sans-serif"],
                FontSize = "14px",
                FontWeight = "400",
                LineHeight = "1.5",
            },
            H1 = new H1Typography { FontFamily = ["Open Sans", "sans-serif"], FontWeight = "700" },
            H2 = new H2Typography { FontFamily = ["Open Sans", "sans-serif"], FontWeight = "700" },
            H3 = new H3Typography { FontFamily = ["Open Sans", "sans-serif"], FontWeight = "700", FontSize = "20px", LetterSpacing = "-0.6px" },
            H4 = new H4Typography { FontFamily = ["Open Sans", "sans-serif"], FontWeight = "700", FontSize = "16px" },
            Button = new ButtonTypography { FontFamily = ["Open Sans", "sans-serif"], FontWeight = "600", FontSize = "14px", TextTransform = "none" },
            Body1 = new Body1Typography { FontFamily = ["Open Sans", "sans-serif"], FontSize = "16px" },
            Body2 = new Body2Typography { FontFamily = ["Open Sans", "sans-serif"], FontSize = "14px" },
        },
        Shape = new Shape
        {
            BorderRadius = 8,
        }
    };
}
